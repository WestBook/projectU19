  "implementationNotes": {
    "security": [
      "在 Spring Boot Controller 使用 @PreAuthorize(\"hasRole('ADMIN')\")",
      "實作 JWT 或 Session-based 認證",
      "在 JWT payload 或 Session 中儲存 role 資訊",
      "使用 Spring Security 設定 /api/admin/** 路徑需要 ADMIN 角色"
    ],
    "validation": [
      "使用 @Valid 和 Bean Validation (javax.validation)",
      "自訂 Validator 檢查業務邏輯（如時間範圍、年齡範圍）",
      "回傳清晰的錯誤訊息給前端"
    ],
    "statistics": [
      "統計資訊應從 orders 表即時計算或使用快取",
      "totalRevenue = SUM(fee) WHERE status = CONFIRMED",
      "pendingRevenue = SUM(fee) WHERE status = PENDING",
      "averageChildAge 可於查詢時計算或預先儲存"
    ]
  }
