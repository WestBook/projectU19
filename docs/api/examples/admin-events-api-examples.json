  "createEvent": {
    "description": "POST /api/admin/events - 管理員建立新賽事",
    "crudFields": {
      "required": {
        "name": {
          "type": "string",
          "constraints": "5-100 字元",
          "description": "賽事名稱"
        },
        "description": {
          "type": "string",
          "constraints": "10-2000 字元",
          "description": "賽事詳細說明"
        },
        "ageMin": {
          "type": "integer",
          "constraints": "1-18",
          "description": "最小參賽年齡"
        },
        "ageMax": {
          "type": "integer",
          "constraints": "1-18，必須 >= ageMin",
          "description": "最大參賽年齡"
        },
        "startTime": {
          "type": "datetime",
          "constraints": "必須 < endTime",
          "description": "賽事開始時間"
        },
        "endTime": {
          "type": "datetime",
          "constraints": "必須 > startTime",
          "description": "賽事結束時間"
        },
        "location": {
          "type": "string",
          "constraints": "3-100 字元",
          "description": "賽事地點"
        },
        "capacity": {
          "type": "integer",
          "constraints": "1-1000",
          "description": "最大參加人數"
        },
        "registrationDeadline": {
          "type": "datetime",
          "constraints": "必須 < startTime",
          "description": "報名截止時間"
        },
        "fee": {
          "type": "decimal",
          "constraints": ">= 0",
          "description": "報名費用（新台幣）"
        },
        "organizer": {
          "type": "string",
          "constraints": "2-100 字元",
          "description": "主辦單位"
        },
        "contactEmail": {
          "type": "string",
          "constraints": "有效的 email 格式",
          "description": "聯絡信箱"
        },
        "contactPhone": {
          "type": "string",
          "constraints": "市話格式 (如 02-1234-5678)",
          "description": "聯絡電話"
        }
      },
      "optional": {
        "address": {
          "type": "string",
          "constraints": "最多 200 字元",
          "description": "詳細地址"
        },
        "ageRestrictionNote": {
          "type": "string",
          "constraints": "最多 200 字元",
          "description": "年齡限制說明（未提供則自動生成）"
        },
        "strictAgeEnforcement": {
          "type": "boolean",
          "constraints": "預設 true",
          "description": "是否嚴格執行年齡限制"
        }
      }
    },
    "validationRules": {
      "businessLogic": [
        "ageMin 必須 <= ageMax",
        "startTime 必須早於 endTime",
        "registrationDeadline 必須早於 startTime",
        "capacity 必須為正整數",
        "fee 必須 >= 0"
      ],
      "autoGenerated": [
        "id - 系統自動生成 UUID",
        "registeredCount - 初始為 0",
        "registrationStatus - 根據當前時間與 registrationDeadline 自動判斷",
        "ageRestriction.description - 若未提供則根據 ageMin/ageMax 自動生成",
        "createdAt, updatedAt - 系統時間戳"
      ]
    },
    "examples": {
      "requests": {
        "basic": {
          "description": "建立基本賽事（僅必填欄位）",
          "body": {
            "name": "2026 春季兒童籃球營",
            "description": "專為 8-12 歲兒童設計的籃球訓練營，由專業教練指導基礎籃球技巧，包含運球、傳球、投籃等基礎訓練。",
            "ageMin": 8,
            "ageMax": 12,
            "startTime": "2026-03-15T09:00:00+08:00",
            "endTime": "2026-03-15T12:00:00+08:00",
            "location": "台北市大安運動中心",
            "capacity": 30,
            "registrationDeadline": "2026-03-10T23:59:59+08:00",
            "fee": 1500,
            "organizer": "台北市籃球協會",
            "contactEmail": "events@basketball.org.tw",
            "contactPhone": "02-1234-5678"
          }
        },
        "complete": {
