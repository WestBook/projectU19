{
  "endpoints": {
    "getEvents": "GET /api/admin/events",
    "createEvent": "POST /api/admin/events"
  },
  "description": "管理員賽事管理 API 範例",
  "authentication": {
    "description": "管理員角色與權限說明",
    "roleAssumption": {
      "overview": "此為示範專案，權限機制採簡化設計。在實際 Production 環境中，需實作完整的認證與授權機制。",
      "productionConsiderations": [
        "使用 JWT (JSON Web Token) 或 Session-based 認證",
        "在 JWT payload 中包含角色資訊 (role: ADMIN)",
        "使用 Spring Security 實作角色驗證",
        "所有 /api/admin/* 路徑需要 ADMIN 角色"
      ],
      "demoAssumption": "在此示範中，假設請求已通過認證機制驗證管理員身份。實際實作時需在 Controller 層加上 @PreAuthorize(\"hasRole('ADMIN')\")"
    },
    "errorCodes": {
      "401": {
        "code": "UNAUTHORIZED",
        "description": "未提供認證憑證或憑證無效",
        "example": "JWT token 遺失或過期"
      },
      "403": {
        "code": "FORBIDDEN",
        "description": "已認證但權限不足",
        "example": "一般使用者嘗試存取管理員 API"
      }
    }
  },
  "getEvents": {
    "description": "GET /api/admin/events - 管理員查詢賽事列表",
    "features": [
      "包含賽事統計資訊（營收、訂單數等）",
      "支援依報名狀態篩選",
      "支援日期區間篩選",
      "預設依建立時間降冪排序（最新在前）"
    ],
    "examples": {
      "requests": {
        "basic": {
          "description": "基本查詢（預設分頁）",
          "url": "/api/admin/events",
          "queryParams": {}
        },
        "filterByStatus": {
          "description": "篩選報名開放中的賽事",
          "url": "/api/admin/events?status=OPEN",
          "queryParams": {
            "status": "OPEN"
          }
        },
        "filterByDateRange": {
          "description": "篩選 3 月份的賽事",
          "url": "/api/admin/events?dateFrom=2026-03-01&dateTo=2026-03-31",
          "queryParams": {
            "dateFrom": "2026-03-01",
            "dateTo": "2026-03-31"
          }
        },
        "withPaginationAndSort": {
          "description": "分頁並依賽事時間排序",
          "url": "/api/admin/events?page=0&size=20&sort=startTime,asc",
          "queryParams": {
            "page": 0,
            "size": 20,
            "sort": "startTime,asc"
          }
        }
      },
      "responses": {
        "success": {
          "httpStatus": 200,
          "description": "成功取得賽事列表（含統計資訊）",
          "body": {
            "success": true,
            "data": [
              {
