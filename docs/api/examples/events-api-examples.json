{
  "endpoint": "GET /api/events",
  "description": "賽事列表查詢 API 範例",
  "examples": {
    "requests": {
      "basic": {
        "description": "基本查詢（使用預設分頁）",
        "url": "/api/events",
        "queryParams": {}
      },
      "filterByAge": {
        "description": "篩選適合 10 歲小孩的賽事",
        "url": "/api/events?age=10",
        "queryParams": {
          "age": 10
        }
      },
      "filterByDateRange": {
        "description": "篩選 2026 年 3 月的賽事",
        "url": "/api/events?dateFrom=2026-03-01&dateTo=2026-03-31",
        "queryParams": {
          "dateFrom": "2026-03-01",
          "dateTo": "2026-03-31"
        }
      },
      "filterByLocation": {
        "description": "篩選台北的賽事",
        "url": "/api/events?location=台北",
        "queryParams": {
          "location": "台北"
        }
      },
      "combinedFilters": {
        "description": "複合條件：台北地區、適合 8 歲、3 月份的賽事",
        "url": "/api/events?age=8&dateFrom=2026-03-01&dateTo=2026-03-31&location=台北",
        "queryParams": {
          "age": 8,
          "dateFrom": "2026-03-01",
          "dateTo": "2026-03-31",
          "location": "台北"
        }
      },
      "withPagination": {
        "description": "指定分頁參數",
        "url": "/api/events?page=1&size=5",
        "queryParams": {
          "page": 1,
          "size": 5
        }
      },
      "withSortingDesc": {
        "description": "依開始時間降冪排序（最新的在前）",
        "url": "/api/events?sort=startTime,desc",
        "queryParams": {
          "sort": "startTime,desc"
        }
      },
      "fullQuery": {
        "description": "完整查詢範例：所有參數",
        "url": "/api/events?age=10&dateFrom=2026-03-01&dateTo=2026-06-30&location=台北&page=0&size=10&sort=startTime,asc",
        "queryParams": {
          "age": 10,
          "dateFrom": "2026-03-01",
          "dateTo": "2026-06-30",
          "location": "台北",
          "page": 0,
          "size": 10,
          "sort": "startTime,asc"
        }
      }
    },
