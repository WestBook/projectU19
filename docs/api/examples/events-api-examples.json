  "aiAgentUsage": {
    "description": "AI Agent 呼叫此 API 的建議用法",
    "toolDefinition": {
      "name": "searchEvents",
      "description": "搜尋兒童體育賽事，可依年齡、日期、地點篩選",
      "parameters": {
        "type": "object",
        "properties": {
          "age": {
            "type": "integer",
            "description": "小孩年齡"
          },
          "dateFrom": {
            "type": "string",
            "description": "開始日期 (YYYY-MM-DD)"
          },
          "dateTo": {
            "type": "string",
            "description": "結束日期 (YYYY-MM-DD)"
          },
          "location": {
            "type": "string",
            "description": "地點關鍵字"
          }
        }
      }
    },
    "exampleConversations": [
      {
        "userQuery": "我的小孩8歲，有什麼適合的運動賽事？",
        "toolCall": {
          "name": "searchEvents",
          "arguments": {
            "age": 8
          }
        }
      },
      {
        "userQuery": "請問台北3月有什麼兒童運動活動？",
        "toolCall": {
          "name": "searchEvents",
          "arguments": {
            "location": "台北",
            "dateFrom": "2026-03-01",
            "dateTo": "2026-03-31"
          }
        }
      }
    ]
  }
}
