  "aiAgentUsage": {
    "description": "AI Agent 呼叫此 API 的建議用法",
    "preConditions": [
      "在呼叫 POST /api/orders 前，建議先呼叫 GET /api/events/{id} 確認賽事詳情",
      "驗證使用者提供的小孩年齡是否符合賽事限制",
      "告知使用者報名費用與付款期限"
    ],
    "toolDefinition": {
      "name": "createEventRegistration",
      "description": "為小孩報名體育賽事",
      "parameters": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "description": "賽事 UUID"
          },
          "parentName": {
            "type": "string",
            "description": "家長姓名"
          },
          "parentEmail": {
            "type": "string",
            "description": "家長電子郵件"
          },
          "parentPhone": {
            "type": "string",
            "description": "家長手機號碼"
          },
          "childName": {
            "type": "string",
            "description": "小孩姓名"
          },
          "childBirthDate": {
            "type": "string",
            "description": "小孩出生日期 (YYYY-MM-DD)"
          },
          "notes": {
            "type": "string",
            "description": "備註（如過敏資訊）"
          }
        },
        "required": ["eventId", "parentName", "parentEmail", "parentPhone", "childName", "childBirthDate"]
      }
    },
