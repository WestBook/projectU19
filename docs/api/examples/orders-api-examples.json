{
  "endpoint": "POST /api/orders",
  "description": "賽事報名訂單 API 範例",
  "validationRules": {
    "description": "請求驗證規則",
    "rules": {
      "eventId": {
        "type": "UUID",
        "required": true,
        "validation": "必須是有效的 UUID 格式且賽事必須存在"
      },
      "parent.name": {
        "type": "string",
        "required": true,
        "minLength": 2,
        "maxLength": 50,
        "validation": "姓名長度 2-50 字元"
      },
      "parent.email": {
        "type": "string",
        "required": true,
        "format": "email",
        "validation": "必須是有效的電子郵件格式"
      },
      "parent.phone": {
        "type": "string",
        "required": true,
        "pattern": "^09\\d{8}$",
        "validation": "必須是台灣手機號碼格式（09 開頭共 10 碼）"
      },
      "child.name": {
        "type": "string",
        "required": true,
        "minLength": 2,
        "maxLength": 50,
        "validation": "姓名長度 2-50 字元"
      },
      "child.birthDate": {
        "type": "date",
        "required": true,
        "format": "YYYY-MM-DD",
        "validation": "出生日期用於計算賽事當日年齡，必須是過去日期（不可為今日或未來日期）"
      },
      "child.gender": {
        "type": "enum",
        "required": false,
        "values": ["MALE", "FEMALE", "OTHER"],
        "validation": "性別（可選）"
      },
      "emergencyContact": {
        "type": "object",
        "required": false,
        "validation": "緊急聯絡人（可選，但若提供則 name 和 phone 必填）"
      },
      "notes": {
        "type": "string",
        "required": false,
        "maxLength": 500,
        "validation": "備註（可選），如過敏資訊、特殊需求等"
      }
    },
    "businessRules": {
      "ageValidation": {
        "description": "年齡驗證規則",
        "rule": "以賽事開始日期計算小孩年齡，必須在 event.ageMin 到 event.ageMax 之間（含）",
        "formula": "childAgeAtEvent = 完整年數(event.startTime.date - child.birthDate)",
        "example": "birthDate=2016-05-15, event.startTime=2026-03-15 → childAgeAtEvent=9（三月尚未過5月生日）",
        "strictEnforcement": {
          "true": "年齡不符合時，拒絕報名（HTTP 409, code: AGE_NOT_ELIGIBLE）",
          "false": "年齡不符合時，允許報名但在 response.data.warnings 中加入 AGE_BOUNDARY_WARNING 提示"
        },
        "birthDateConstraint": "child.birthDate 必須是過去日期（HTTP 400, code: VALIDATION_ERROR 若為未來日期）"
      },
      "capacityCheck": {
        "description": "名額檢查",
        "rule": "event.registeredCount < event.capacity"
      },
      "registrationStatus": {
        "description": "報名狀態檢查",
        "rule": "event.registrationStatus 必須為 OPEN"
      },
      "duplicateCheck": {
        "description": "重複報名檢查",
        "rule": "同一小孩（依 child.name + child.birthDate 判斷）不可重複報名同一賽事",
        "errorOnDuplicate": "HTTP 409, code: DUPLICATE_REGISTRATION"
      },
      "paymentDeadline": {
        "description": "付款期限計算",
        "formula": "paymentDeadline = min(event.registrationDeadline, 訂單建立時間 + 72小時)",
        "example": "若 registrationDeadline=2026-03-10T23:59:59，訂單建立於 2026-01-26T10:30:00，則 paymentDeadline=2026-01-29T10:30:00"
      }
    }
  },
  "orderStatusLifecycle": {
    "description": "訂單狀態生命週期",
    "states": {
      "PENDING": {
        "description": "待付款",
        "entryCondition": "訂單建立成功",
        "nextStates": ["CONFIRMED", "CANCELLED"],
        "autoTransition": {
          "to": "CANCELLED",
          "condition": "超過付款期限 (paymentDeadline)",
          "description": "系統自動取消逾期未付款訂單"
        }
      },
      "CONFIRMED": {
        "description": "已確認",
        "entryCondition": "付款成功",
        "nextStates": ["REFUNDED", "COMPLETED"],
        "actions": ["可申請退款（依退款政策）", "等待賽事進行"]
      },
      "CANCELLED": {
        "description": "已取消",
        "entryCondition": "使用者主動取消 或 逾期未付款",
        "nextStates": [],
        "terminal": true,
        "note": "已取消的訂單無法恢復"
      },
      "REFUNDED": {
        "description": "已退款",
        "entryCondition": "退款申請通過 或 賽事取消",
        "nextStates": [],
        "terminal": true
      },
      "COMPLETED": {
        "description": "已完成",
        "entryCondition": "賽事結束",
        "nextStates": [],
        "terminal": true
      }
    },
    "diagram": "PENDING ─付款完成─→ CONFIRMED ─賽事結束─→ COMPLETED\n   │                      │\n   │（使用者取消/逾期）   │（退款申請通過/賽事取消）\n   ↓                      ↓\nCANCELLED              REFUNDED",
    "transitionRules": {
      "PENDING_to_CONFIRMED": "付款成功後由系統或 webhook 觸發",
      "PENDING_to_CANCELLED": "使用者主動取消，或超過 paymentDeadline 系統自動取消",
      "CONFIRMED_to_COMPLETED": "賽事 endTime 過後由系統批次更新",
      "CONFIRMED_to_REFUNDED": "使用者申請退款且通過審核，或賽事主辦方取消賽事"
    }
  },
