      "mockApiResponses": {
        "searchEvents": {
          "found": 1,
          "events": [
            { "id": "11111111-aaaa-bbbb-cccc-000000000001", "name": "暑期籃球夏令營", "ageRange": "8-14 歲", "startTime": "2026-07-01T08:00:00+08:00", "location": "台北市", "registrationStatus": "OPEN" }
          ],
