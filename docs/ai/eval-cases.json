{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "AI 客服 Agent 評估案例集 v1.0 — 15 個案例，涵蓋 Normal / Edge / Missing Info 三類",
  "version": "1.0",
  "evaluationGuide": {
    "toolCallCheck": "驗證 expectedToolCalls：工具名稱與 inputContains 的每個欄位值必須完全符合；若 shouldNotCall=true 則不得呼叫任何工具",
    "answerCheck": "驗證 passCriteria：type=answer_contains 的 value 必須出現在 answer 中；type=answer_not_contains 的 value 不得出現",
    "sourcesCheck": "驗證 passCriteria：type=sources_min_count 時 sources 長度 >= value；type=sources_empty 時 sources 必須是空陣列",
    "suggestionsCheck": "驗證 passCriteria：type=suggestions_include_action 時 suggestions 中至少一個 action 等於 value",
    "clarificationCheck": "type=asks_clarification 時 answer 必須包含問號（?）且不得先呼叫任何工具",
    "hallucination": "type=no_fabricated_ids 時：answer 中出現的所有 UUID 格式字串，必須全部出現在 mockApiResponses 回傳的 id 欄位中",
    "noTechJargon": "type=no_tech_jargon 時：answer 不得包含 'HTTP'、'API'、'409'、'404'、'500' 等技術詞彙"
  },
  "cases": [
    {
      "id": "N01",
      "category": "normal",
      "description": "基本依年齡搜尋：使用者明確說出孩子年齡，Agent 應直接呼叫 searchEvents 並回傳帶有 eventId 的清單",
      "conversationHistory": [],
      "userInput": "我想找適合 9 歲小孩的籃球活動",
      "mockApiResponses": {
        "searchEvents": {
          "found": 3,
          "events": [
            { "id": "aaaaaaaa-0001-0001-0001-000000000001", "name": "兒童籃球夏令營", "ageRange": "8-12 歲", "startTime": "2026-03-15T08:00:00+08:00", "location": "台北市大安區", "registrationStatus": "OPEN" },
            { "id": "aaaaaaaa-0001-0001-0001-000000000002", "name": "春季籃球基礎訓練", "ageRange": "7-11 歲", "startTime": "2026-03-22T09:00:00+08:00", "location": "新北市板橋區", "registrationStatus": "OPEN" },
            { "id": "aaaaaaaa-0001-0001-0001-000000000003", "name": "親子籃球體驗日", "ageRange": "6-12 歲", "startTime": "2026-04-05T10:00:00+08:00", "location": "桃園市中壢區", "registrationStatus": "OPEN" }
          ],
          "page": { "page": 0, "size": 10, "totalElements": 3, "totalPages": 1, "hasNext": false, "hasPrevious": false }
        }
      },
      "expectedToolCalls": [
        { "name": "searchEvents", "inputContains": { "age": 9 } }
      ],
      "passCriteria": [
        { "type": "tool_called", "value": "searchEvents" },
        { "type": "answer_contains", "value": "aaaaaaaa-0001-0001-0001-000000000001", "description": "必須引用第一個賽事的 eventId" },
        { "type": "answer_contains", "value": "aaaaaaaa-0001-0001-0001-000000000002", "description": "必須引用第二個賽事的 eventId" },
        { "type": "sources_min_count", "value": 3, "description": "sources 應包含所有回傳賽事" },
        { "type": "suggestions_include_action", "value": "VIEW_EVENT_DETAIL", "description": "應提供至少一個查看詳情的建議" },
        { "type": "no_fabricated_ids" },
        { "type": "no_tech_jargon" }
      ],
      "failExamples": [
        "春季籃球基礎訓練是個很好的活動，我相信您會喜歡（未呼叫工具，捏造評論）",
        "目前有籃球夏令營，費用大約 2000 元（未呼叫工具即給出費用資訊）"
      ]
    },
    {
      "id": "N02",
      "category": "normal",
      "description": "加入地點與日期篩選：搜尋條件應完整傳遞給工具",
      "conversationHistory": [],
      "userInput": "台北有沒有適合 10 歲的游泳活動，3 月份的",
      "mockApiResponses": {
        "searchEvents": {
          "found": 1,
          "events": [
            { "id": "bbbbbbbb-0002-0002-0002-000000000001", "name": "兒童游泳精進班", "ageRange": "8-12 歲", "startTime": "2026-03-10T09:00:00+08:00", "location": "台北市中山區", "registrationStatus": "OPEN" }
          ],
          "page": { "page": 0, "size": 10, "totalElements": 1, "totalPages": 1, "hasNext": false, "hasPrevious": false }
        }
      },
      "expectedToolCalls": [
        {
          "name": "searchEvents",
          "inputContains": {
            "age": 10,
            "location": "台北",
            "dateFrom": "2026-03-01",
            "dateTo": "2026-03-31"
          }
        }
      ],
      "passCriteria": [
        { "type": "tool_called", "value": "searchEvents" },
        { "type": "answer_contains", "value": "bbbbbbbb-0002-0002-0002-000000000001" },
        { "type": "sources_min_count", "value": 1 },
        { "type": "no_fabricated_ids" }
      ],
      "failExamples": [
        "searchEvents 呼叫中缺少 location 參數",
        "searchEvents 呼叫中年齡用了 9 或 11 而非 10"
      ]
    },
    {
      "id": "N03",
      "category": "normal",
      "description": "多輪對話：搜尋後使用者詢問特定賽事詳情，Agent 應正確呼叫 getEventDetail 並使用 searchEvents 回傳的 ID",
      "conversationHistory": [
        {
          "role": "user",
          "content": "找 9 歲的籃球活動"
        },
        {
          "role": "assistant",
          "content": "找到兒童籃球夏令營（ID: aaaaaaaa-0001-0001-0001-000000000001）等 2 個活動，請問您想了解哪一個？",
          "seenEventIds": ["aaaaaaaa-0001-0001-0001-000000000001", "cccccccc-0003-0003-0003-000000000001"]
        }
      ],
      "userInput": "第一個的費用是多少？報名截止是哪天？",
      "mockApiResponses": {
        "getEventDetail": {
          "id": "aaaaaaaa-0001-0001-0001-000000000001",
          "name": "兒童籃球夏令營",
          "fee": 2000,
          "registrationDeadline": "2026-03-10T23:59:00+08:00",
          "capacity": 30,
          "registeredCount": 25,
          "registrationStatus": "OPEN",
          "ageRestriction": { "minAge": 8, "maxAge": 12, "description": "8-12 歲", "strictEnforcement": true },
          "startTime": "2026-03-15T08:00:00+08:00",
          "location": "台北市大安區"
        }
      },
      "expectedToolCalls": [
        {
          "name": "getEventDetail",
          "inputContains": { "id": "aaaaaaaa-0001-0001-0001-000000000001" }
        }
      ],
      "passCriteria": [
        { "type": "tool_called", "value": "getEventDetail" },
        { "type": "answer_contains", "value": "2,000", "description": "費用必須出現在回答中" },
        { "type": "answer_contains", "value": "2026-03-10", "description": "截止日期必須出現在回答中" },
        { "type": "answer_contains", "value": "aaaaaaaa-0001-0001-0001-000000000001", "description": "回覆中必須引用 eventId" },
        { "type": "sources_min_count", "value": 1 },
        { "type": "no_fabricated_ids" }
      ],
      "failExamples": [
        "費用大約是 1500-2500 元左右（捏造費用範圍而非引用 API 回傳值）",
        "呼叫 getEventDetail 時使用了不在 seenEventIds 中的 ID"
      ]
    },
    {
      "id": "N04",
      "category": "normal",
      "description": "搜尋結果為空：Agent 應如實告知且提出放寬建議，不得捏造任何賽事",
      "conversationHistory": [],
      "userInput": "高雄有沒有 16 歲的羽球活動？",
      "mockApiResponses": {
        "searchEvents": {
          "found": 0,
          "events": [],
          "message": "沒有符合條件的賽事。建議放寬年齡、地點或日期範圍。",
          "page": { "page": 0, "size": 10, "totalElements": 0, "totalPages": 0, "hasNext": false, "hasPrevious": false }
        }
      },
      "expectedToolCalls": [
        { "name": "searchEvents", "inputContains": { "age": 16, "location": "高雄" } }
      ],
      "passCriteria": [
        { "type": "tool_called", "value": "searchEvents" },
        { "type": "answer_contains", "value": "沒有", "description": "必須告知查無結果" },
        { "type": "sources_empty", "description": "查無結果時 sources 必須為空陣列" },
        { "type": "suggestions_include_action", "value": "SEARCH_EVENTS", "description": "應建議使用者重新搜尋" },
        { "type": "no_fabricated_ids" },
        { "type": "answer_not_contains", "value": "我推薦", "description": "不可在無資料情況下推薦任何活動" }
      ],
      "failExamples": [
        "高雄目前有幾個羽球活動，建議您可以試試中山體育館（捏造不存在的活動）",
        "sources 中出現任何 eventId（查無結果不應有任何來源）"
      ]
    },
    {
      "id": "N05",
      "category": "normal",
      "description": "引導報名：看完詳情後使用者決定報名，Agent 應引導至報名頁面並提供 START_REGISTRATION 建議",
      "conversationHistory": [
        {
          "role": "user",
          "content": "兒童籃球夏令營還有名額嗎？"
        },
        {
          "role": "assistant",
          "content": "兒童籃球夏令營（ID: aaaaaaaa-0001-0001-0001-000000000001）共 30 個名額，目前剩餘 5 個，報名截止 2026-03-10。",
          "seenEventIds": ["aaaaaaaa-0001-0001-0001-000000000001"]
        }
      ],
      "userInput": "好，我想報名這個活動",
      "mockApiResponses": {},
      "expectedToolCalls": [],
      "passCriteria": [
        { "type": "no_tool_calls", "description": "資訊已知，不需再呼叫工具" },
        { "type": "suggestions_include_action", "value": "START_REGISTRATION" },
        { "type": "answer_contains", "value": "aaaaaaaa-0001-0001-0001-000000000001", "description": "引導報名時必須引用 eventId" },
        { "type": "answer_not_contains", "value": "身分證", "description": "不應要求非必要個資" }
      ],
      "failExamples": [
        "呼叫 getEventDetail 重複查詢已知資訊（浪費工具呼叫）",
        "回應中沒有提供報名頁面的引導"
      ]
    },
    {
      "id": "E01",
      "category": "edge",
      "description": "年齡恰好在最小值邊界（ageMin=8，孩子=8歲）：應視為符合資格，不顯示任何警告",
      "conversationHistory": [],
      "userInput": "我 8 歲的小孩可以參加這個活動嗎？",
      "mockApiResponses": {
        "searchEvents": {
          "found": 1,
          "events": [
            { "id": "dddddddd-0004-0004-0004-000000000001", "name": "兒童籃球體能訓練", "ageRange": "8-12 歲", "startTime": "2026-04-01T09:00:00+08:00", "location": "台北市", "registrationStatus": "OPEN" }
          ],
          "page": { "page": 0, "size": 10, "totalElements": 1, "totalPages": 1, "hasNext": false, "hasPrevious": false }
        },
        "getEventDetail": {
          "id": "dddddddd-0004-0004-0004-000000000001",
          "name": "兒童籃球體能訓練",
          "ageRestriction": { "minAge": 8, "maxAge": 12, "description": "8-12 歲", "strictEnforcement": true },
          "capacity": 20, "registeredCount": 10,
          "fee": 1800,
          "registrationDeadline": "2026-03-25T23:59:00+08:00",
          "registrationStatus": "OPEN",
          "startTime": "2026-04-01T09:00:00+08:00",
          "location": "台北市"
        }
      },
      "expectedToolCalls": [
        { "name": "searchEvents", "inputContains": { "age": 8 } }
      ],
      "passCriteria": [
        { "type": "tool_called", "value": "searchEvents" },
        { "type": "answer_not_contains", "value": "不符合", "description": "8 歲符合 8-12 範圍，不應說不符合" },
        { "type": "answer_not_contains", "value": "警告", "description": "嚴格模式邊界內不應有警告" },
        { "type": "no_fabricated_ids" }
      ],
      "failExamples": [
        "您的小孩 8 歲，稍微低於建議年齡（錯誤：8 ≥ ageMin=8，符合資格）",
        "此活動需要 8 歲以上（正確）但又說可能有限制（矛盾）"
      ]
    },
    {
      "id": "E02",
      "category": "edge",
      "description": "年齡恰好在最大值邊界（ageMax=12，孩子=12歲）：應視為符合資格",
      "conversationHistory": [],
      "userInput": "我小孩 12 歲，適合參加 8-12 歲的活動嗎？",
      "mockApiResponses": {
        "searchEvents": {
          "found": 1,
          "events": [
            { "id": "eeeeeeee-0005-0005-0005-000000000001", "name": "籃球技術精進班", "ageRange": "8-12 歲", "startTime": "2026-04-10T09:00:00+08:00", "location": "新北市", "registrationStatus": "OPEN" }
          ],
          "page": { "page": 0, "size": 10, "totalElements": 1, "totalPages": 1, "hasNext": false, "hasPrevious": false }
        }
      },
      "expectedToolCalls": [
        { "name": "searchEvents", "inputContains": { "age": 12 } }
      ],
      "passCriteria": [
        { "type": "tool_called", "value": "searchEvents" },
        { "type": "answer_not_contains", "value": "不符合" },
        { "type": "answer_not_contains", "value": "超出" },
        { "type": "no_fabricated_ids" }
      ],
      "failExamples": [
        "您的小孩 12 歲已超出最大年齡限制（錯誤：12 ≤ ageMax=12，符合資格）"
      ]
    },
    {
      "id": "E03",
      "category": "edge",
      "description": "彈性年齡模式（strictEnforcement=false，孩子 13 歲，活動範圍 8-12）：允許報名但必須顯示年齡警告",
      "conversationHistory": [
        {
          "role": "user",
          "content": "我 13 歲的小孩想報名親子籃球體驗日"
        },
        {
          "role": "assistant",
          "content": "找到親子籃球體驗日（ID: ffffffff-0006-0006-0006-000000000001），讓我查詢詳情。",
          "seenEventIds": ["ffffffff-0006-0006-0006-000000000001"]
        }
      ],
      "userInput": "這個活動他可以參加嗎？",
      "mockApiResponses": {
        "getEventDetail": {
          "id": "ffffffff-0006-0006-0006-000000000001",
          "name": "親子籃球體驗日",
          "ageRestriction": { "minAge": 8, "maxAge": 12, "description": "8-12 歲（彈性）", "strictEnforcement": false },
          "capacity": 30, "registeredCount": 10,
          "fee": 800,
          "registrationDeadline": "2026-04-01T23:59:00+08:00",
          "registrationStatus": "OPEN",
          "startTime": "2026-04-05T10:00:00+08:00",
          "location": "桃園市中壢區"
        }
      },
      "expectedToolCalls": [
        { "name": "getEventDetail", "inputContains": { "id": "ffffffff-0006-0006-0006-000000000001" } }
      ],
      "passCriteria": [
        { "type": "tool_called", "value": "getEventDetail" },
        { "type": "answer_contains", "value": "13", "description": "必須明確提到孩子的年齡" },
        { "type": "answer_contains", "value": "彈性", "description": "必須說明這是彈性年齡規定" },
        { "type": "answer_contains", "value": "警告", "description": "應告知報名後會出現警告訊息，或以相近措辭說明" },
        { "type": "suggestions_include_action", "value": "START_REGISTRATION", "description": "彈性模式仍應提供報名入口" },
        { "type": "no_fabricated_ids" }
      ],
      "failExamples": [
        "不允許報名，年齡不符合（錯誤：彈性模式應允許報名）",
        "可以直接報名（未告知年齡警告）"
      ]
    },
    {
      "id": "E04",
      "category": "edge",
      "description": "最後一個名額：Agent 應特別強調緊迫性，避免使用者錯失",
