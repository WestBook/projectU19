          "registrationStatus": "OPEN",
          "fee": 3500,
          "registrationDeadline": "2026-06-15T23:59:00+08:00",
          "startTime": "2026-07-01T08:00:00+08:00",
          "location": "台北市"
        }
      },
      "expectedToolCalls": [
        { "name": "searchEvents" },
        { "name": "getEventDetail", "inputContains": { "id": "11111111-aaaa-bbbb-cccc-000000000001" } }
      ],
      "passCriteria": [
        { "type": "answer_contains", "value": "1", "description": "應明確說明只剩 1 個名額" },
        { "type": "answer_contains", "value": "11111111-aaaa-bbbb-cccc-000000000001" },
        { "type": "suggestions_include_action", "value": "START_REGISTRATION", "description": "剩最後名額應主動提供報名入口" },
        { "type": "no_fabricated_ids" }
      ],
      "failExamples": [
        "名額還很充裕（錯誤：只剩 1 個）",
        "還有幾個名額（模糊說法，應明確說「1 個」）"
      ]
